ninja_required_version = 1.3
cxx = /home/jliangbr/miniconda3/envs/lut_net/bin/x86_64-conda-linux-gnu-c++
nvcc = /home/jliangbr/miniconda3/envs/lut_net/bin/nvcc

cflags = -march=nocona -mtune=haswell -ftree-vectorize -fPIC -fstack-protector-strong -fno-plt -O2 -ffunction-sections -pipe -isystem /home/jliangbr/miniconda3/envs/lut_net/include -I/home/jliangbr/miniconda3/envs/lut_net/targets/x86_64-linux/include -I/home/jliangbr/miniconda3/envs/lut_net/targets/x86_64-linux/include/cccl -DNDEBUG -D_FORTIFY_SOURCE=2 -O2 -isystem /home/jliangbr/miniconda3/envs/lut_net/include -I/home/jliangbr/miniconda3/envs/lut_net/targets/x86_64-linux/include -I/home/jliangbr/miniconda3/envs/lut_net/targets/x86_64-linux/include/cccl -fPIC -I/home/jliangbr/miniconda3/envs/lut_net/lib/python3.10/site-packages/torch/include -I/home/jliangbr/miniconda3/envs/lut_net/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/home/jliangbr/miniconda3/envs/lut_net/include -I/home/jliangbr/miniconda3/envs/lut_net/include/python3.10 -c
post_cflags = -O3 -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=lut_cuda_binary -std=c++17
cuda_cflags = -I/home/jliangbr/miniconda3/envs/lut_net/lib/python3.10/site-packages/torch/include -I/home/jliangbr/miniconda3/envs/lut_net/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/home/jliangbr/miniconda3/envs/lut_net/include -I/home/jliangbr/miniconda3/envs/lut_net/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -O3 -U__CUDA_NO_HALF_OPERATORS__ -U__CUDA_NO_HALF_CONVERSIONS__ -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=lut_cuda_binary -gencode=arch=compute_89,code=compute_89 -gencode=arch=compute_89,code=sm_89 -ccbin /home/jliangbr/miniconda3/envs/lut_net/bin/x86_64-conda-linux-gnu-cc -std=c++17
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







build /home/jliangbr/workspace/complexPyTorch/lut_cuda/build/temp.linux-x86_64-cpython-310/lut_conv_binary_cuda_backend.o: cuda_compile /home/jliangbr/workspace/complexPyTorch/lut_cuda/lut_conv_binary_cuda_backend.cu








